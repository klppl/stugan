# Binaries (the compiled daemon; anchored so it can't match cmd/stugan/)
/stugan
/client/stugan
/dist/
*.exe

# Local runtime data (when STUGAN_HOME points inside the repo for dev)
/data/
/scripts/
# per-user data/scripts in multi-user mode
/users/
# disposable home from `./stugan -home ./dev`
/dev/
config.toml

# SQLite history database (+ WAL/SHM sidecars from journal_mode=WAL)
*.db
*.db-wal
*.db-shm
*.db-journal

# Secrets / local environment
.env
.env.*
!.env.example

# Go
*.test
*.out
/coverage.*
go.work
go.work.sum

# Frontend
client/node_modules/
client/dist/
*.tsbuildinfo
*.local
npm-debug.log*
yarn-error.log*
*.log

# Editor/OS
.DS_Store
*.swp
.idea/
.vscode/

# Local-only Claude Code settings (personal tool permissions; not shared)
.claude/settings.local.json
